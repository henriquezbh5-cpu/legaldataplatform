# Caddy reverse proxy config for LegalDataPlatform live demo on a VPS.
#
# Features:
#   - Automatic HTTPS via Let's Encrypt (just own the domain)
#   - Basic auth on all UIs (so the demo is not open to the internet)
#   - Each service on its own subdomain
#
# Usage:
#   1. Point subdomains to your VPS IP:
#        prefect.tudominio.com  A  <vps_ip>
#        minio.tudominio.com    A  <vps_ip>
#        grafana.tudominio.com  A  <vps_ip>
#        docs.tudominio.com     A  <vps_ip>
#
#   2. Generate a basic-auth hash:
#        docker run --rm caddy:latest caddy hash-password --plaintext "tu_password"
#      Copy the output (starts with $2a$) into the `basicauth` blocks below.
#
#   3. Save this file as /etc/caddy/Caddyfile on the VPS.
#
#   4. Run Caddy as a container alongside your stack:
#        docker run -d --name caddy \
#          --network=ldp_default \
#          -p 80:80 -p 443:443 \
#          -v /etc/caddy/Caddyfile:/etc/caddy/Caddyfile:ro \
#          -v caddy_data:/data -v caddy_config:/config \
#          caddy:latest

# -----------------------------------------------------------------------------
# Static docs (no auth - portfolio-facing)
# -----------------------------------------------------------------------------
docs.tudominio.com {
    root * /srv/docs
    file_server
    encode gzip zstd
    header {
        # Basic security headers
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
    }
}

# -----------------------------------------------------------------------------
# Prefect UI (with basic auth)
# -----------------------------------------------------------------------------
prefect.tudominio.com {
    basicauth {
        # Generate with: caddy hash-password --plaintext "tu_password"
        demo $2a$14$REPLACE_WITH_HASH_OF_YOUR_PASSWORD
    }
    reverse_proxy prefect:4200
}

# -----------------------------------------------------------------------------
# MinIO Console (with basic auth)
# -----------------------------------------------------------------------------
minio.tudominio.com {
    basicauth {
        demo $2a$14$REPLACE_WITH_HASH_OF_YOUR_PASSWORD
    }
    reverse_proxy minio:9001
}

# -----------------------------------------------------------------------------
# Grafana (Grafana has its own auth, so no basicauth layer needed)
# -----------------------------------------------------------------------------
grafana.tudominio.com {
    reverse_proxy grafana:3000
}

# -----------------------------------------------------------------------------
# NOT exposed publicly (keep internal):
#   - PostgreSQL 5432
#   - PgBouncer 6432
#   - MinIO API 9000
#   - Prometheus 9090
# Access those only via SSH tunnel.
# -----------------------------------------------------------------------------
