# Application
APP_ENV=development
APP_LOG_LEVEL=INFO

# PostgreSQL (direct connection)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=legaldata
POSTGRES_USER=ldp_admin
POSTGRES_PASSWORD=ldp_dev_password

# PgBouncer (pooled)
PGBOUNCER_HOST=localhost
PGBOUNCER_PORT=6432

# AWS (use MinIO locally)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
AWS_S3_ENDPOINT=http://localhost:9000
S3_BRONZE_BUCKET=bronze
S3_SILVER_BUCKET=silver
S3_GOLD_BUCKET=gold
S3_QUARANTINE_BUCKET=quarantine

# Prefect
PREFECT_API_URL=http://localhost:4200/api

# Data sources
LEGAL_API_BASE_URL=https://api.legal.example.com
LEGAL_API_KEY=replace_me
COMMERCIAL_SFTP_HOST=sftp.example.com
COMMERCIAL_SFTP_USER=replace_me
COMMERCIAL_SFTP_PASSWORD=replace_me

# SEC EDGAR requires a User-Agent with contact email per their fair-use policy
# (https://www.sec.gov/developer). Replace with your real email before running
# the sec_edgar_ingestion_flow.
SEC_USER_AGENT=LegalDataPlatform/0.1 (your-email@example.com)

# Data Quality
GE_DATA_DOCS_DIR=./data_docs
DQ_FAIL_FAST=false

# Observability
PROMETHEUS_PUSHGATEWAY=http://localhost:9091
